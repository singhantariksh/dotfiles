#!/bin/bash

FILE="$HOME/.config/niri/input.kdl"
KEYWORD="disabled-on-external-mouse"

# Check if the file exists
if [ ! -f "$FILE" ]; then
    echo "Error: Configuration file not found at $FILE"
    exit 1
fi

# Check if the line is currently commented out
if grep -q "^\s*//\s*$KEYWORD" "$FILE"; then
    # It is commented: Uncomment it
    sed -i "s|^\(\s*\)//\s*$KEYWORD|\1$KEYWORD|" "$FILE"
    qs -c noctalia-shell ipc call toast send '{"title": "Touchpad Disabled", "icon": "device-ipad-off" ,"duration": 1600}'
else
    # It is active: Comment it out
    sed -i "s|^\(\s*\)$KEYWORD|\1// $KEYWORD|" "$FILE"
    qs -c noctalia-shell ipc call toast send '{"title": "Touchpad Enabled", "icon": "device-ipad-check" ,"duration": 1600}'
fi
